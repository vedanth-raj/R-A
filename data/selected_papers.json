    "paperId": "6c3be6d2b84a0a3454d4edddf20258a4e2f84247",
    "title": "In situ Growth of Cu2O/CuO Nanosheets on Cu Coating Carbon Cloths as a Binder-Free Electrode for Asymmetric Supercapacitors",
    "authors": [
      {
        "authorId": "2152895503",
        "name": "Li'na Xu"
      },
      {
        "authorId": "49298452",
        "name": "Jiao Li"
      },
      {
        "authorId": "47218011",
